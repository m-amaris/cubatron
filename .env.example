# Cubatron environment template
# Copy values into your deployment secret store or systemd Environment.

# JWT signing key (required in production)
CUBATRON_SECRET_KEY=replace-with-a-long-random-secret

# Optional bootstrap admin created on startup only if the user does not exist.
CUBATRON_BOOTSTRAP_ADMIN_USER=admin
CUBATRON_BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password
CUBATRON_BOOTSTRAP_ADMIN_FULLNAME=Administrador

# UART / STM32
CUBATRON_UART_ENABLED=1
CUBATRON_UART_DRY_RUN=1
CUBATRON_UART_ENFORCE_TANKS=1
CUBATRON_UART_PORT=/dev/serial0
CUBATRON_UART_BAUDRATE=115200
CUBATRON_UART_TIMEOUT=0.5
CUBATRON_UART_WRITE_TIMEOUT=0.5
CUBATRON_UART_LOG_PATH=/opt/cubatron/data/uart.log
